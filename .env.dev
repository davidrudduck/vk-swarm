# Local node development environment
# Usage: pnpm run dev (or pnpm run dev:network for 0.0.0.0)

# Bind on all interfaces for network access
HOST=0.0.0.0

# Frontend port (node UI)
FRONTEND_PORT=3000

# Backend port
BACKEND_PORT=3001

# Connect to the hive running in Docker
VK_HIVE_URL=ws://localhost:9000
VK_NODE_API_KEY=vk_e2e-primary-key-12345678

# Node identity
VK_NODE_NAME=local-dev-node

# Public URL for direct log streaming (hive can reach back)
VK_NODE_PUBLIC_URL=http://localhost:3000

# JWT secret (must match hive's VIBEKANBAN_REMOTE_JWT_SECRET)
VK_CONNECTION_TOKEN_SECRET=dGVzdC1qd3Qtc2VjcmV0LWZvci1sb2NhbC1kZXYtZW52aXJvbm1lbnQtc2VjcmV0

# Logging
RUST_LOG=info

# Keep executor processes alive on shutdown
VK_DISABLE_PROCESS_KILL_ON_SHUTDOWN=1
