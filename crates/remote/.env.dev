# Remote hive (Docker) development environment
# Usage: cd crates/remote && docker compose -f docker-compose.dev.yml --env-file .env.dev up --build

# PostgreSQL
POSTGRES_DB=vibe_remote
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5434

# Remote server — bind on 0.0.0.0 for network access
SERVER_PORT=9000
SERVER_LISTEN_ADDR=0.0.0.0:8081
# Public URLs use localhost (not 0.0.0.0) for browser compatibility
SERVER_PUBLIC_BASE_URL=http://localhost:9000
VITE_APP_BASE_URL=http://localhost:9000
VITE_API_BASE_URL=http://localhost:9000

# Dummy OAuth (server requires at least one provider)
GITHUB_OAUTH_CLIENT_ID=dummy-github-client-id-for-dev
GITHUB_OAUTH_CLIENT_SECRET=dummy-github-client-secret-for-dev

# JWT secret (base64-encoded, min 32 bytes)
VIBEKANBAN_REMOTE_JWT_SECRET=dGVzdC1qd3Qtc2VjcmV0LWZvci1sb2NhbC1kZXYtZW52aXJvbm1lbnQtc2VjcmV0

# Required by server
LOOPS_EMAIL_API_KEY=dummy

# Logging
RUST_LOG=info

# Connection pool
VK_PG_MAX_CONNECTIONS=10

# Build args
PNPM_VERSION=10.25.0
VK_GIT_COMMIT=dev
VK_GIT_BRANCH=artful-egret
